# ── Public (shipped to client bundle) ──
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry browser DSN (leave empty to disable observability entirely).
VITE_SENTRY_DSN=
# Optional release tag — set to commit SHA in CI for source-maps association.
VITE_RELEASE=

# ── Server-only (Vercel serverless functions) ──
# Supabase service-role key — used by api/manifesto/sign.js to bypass RLS for
# inserts. NEVER commit this value or expose it to the client. Bundle secret
# check fails the deploy if it ever leaks into dist/.
SUPABASE_SERVICE_ROLE_KEY=

# Random 32-byte secret used to salt the IP hash stored alongside manifesto
# signatures. Rotating this invalidates the per-IP-per-day uniqueness window.
MANIFESTO_IP_SALT=

# XQuik X-platform proxy
XQUIK_API_KEY=your_xquik_key

# Google Gemini
GEMINI_API_KEY=your_gemini_key
# Model selection — pin to a specific build for reproducibility.
# Allowed: gemini-3-pro-preview | gemini-3-flash-preview | gemini-3-pro-image-preview
GEMINI_MODEL=gemini-3-flash-preview
# Endpoint (defaults to scheme=https + version=v1beta if omitted; HOST is required).
GEMINI_API_HOST=generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
GEMINI_API_SCHEME=https
