# ── Public (shipped to client bundle) ──
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry browser DSN (leave empty to disable observability entirely).
VITE_SENTRY_DSN=
# Optional release tag — set to commit SHA in CI for source-maps association.
VITE_RELEASE=

# ── Server-only (Vercel serverless functions) ──
# XQuik X-platform proxy
XQUIK_API_KEY=your_xquik_key

# Google Gemini
GEMINI_API_KEY=your_gemini_key
# Model selection — pin to a specific build for reproducibility.
# Allowed: gemini-3-pro-preview | gemini-3-flash-preview | gemini-3-pro-image-preview
GEMINI_MODEL=gemini-3-flash-preview
# Endpoint (defaults to scheme=https + version=v1beta if omitted; HOST is required).
GEMINI_API_HOST=generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
GEMINI_API_SCHEME=https
